# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase — Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# The anon key is intentionally public — it is safe in the client bundle.
# RLS is the security boundary, not key secrecy. See README Key Decisions.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# WARNING: never add SUPABASE_SERVICE_ROLE_KEY here or any VITE_-prefixed variable.
# The service role key bypasses RLS entirely and must never touch the frontend.

# Google OAuth credentials are NOT stored here.
# Configure them inside Supabase: Authentication > Providers > Google.
# The only values you set in Netlify env vars are the two VITE_ vars above.
